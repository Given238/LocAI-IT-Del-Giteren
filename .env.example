DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require
LLM_API_KEY=your_key_here
LLM_BASE_URL=https://api.sea-lion.ai/v1
LLM_MODEL=aisingapore/Gemma-SEA-LION-v4-27B-IT
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google OAuth (optional -- "Continue with Google" gracefully disables
# itself via GET /auth/config if these aren't set). Create a client at
# https://console.cloud.google.com/apis/credentials, authorized redirect
# URI must match GOOGLE_OAUTH_REDIRECT_URI exactly.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Reserved for future cookie-signing/CSRF-token hardening -- not required
# by the current session design (backend/auth.py uses a random opaque
# token looked up in the sessions table). Fine to leave unset.
SESSION_SECRET=

# Cookie attributes -- defaults are fine for local dev over plain HTTP.
# Set COOKIE_SECURE=true in production (HTTPS). Only set COOKIE_SAMESITE=none
# if the frontend and backend end up on genuinely different sites (not
# just different localhost ports); that also requires COOKIE_SECURE=true.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
